doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title
    link(rel="stylesheet" href="/public/styles.css")
  body
    main.page.page--top
      section.card
        h1= heading
        if errorMessage
          p.error-message= errorMessage
        form.user-form(action=formAction method="post")
          label.form-field(for="name") Имя
          input#name.input(type="text" name="name" value=formData.name placeholder="Введите имя" required)
          label.form-field(for="email") Email
          input#email.input(type="email" name="email" value=formData.email placeholder="Введите email" required)
          button.button(type="submit")= submitLabel
        nav.links
          a.link(href="/users") К списку пользователей
