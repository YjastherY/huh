doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title
    link(rel="stylesheet" href="/public/styles.css")
  body
    main.page.page--top
      section.card
        h1 Список пользователей
        if users.length
          ul.user-list
            each user in users
              li.user-item
                span.user-id ID #{user.id}
                strong.user-name= user.name
                a.user-email(href=`mailto:${user.email}`)= user.email
                div.user-actions
                  a.link(href=`/users/${user.id}/edit`) Редактировать
                  form.inline-form(action=`/users/${user.id}/delete` method="post")
                    button.button.button-secondary(type="submit") Удалить
        else
          p Пользователи пока не добавлены.
        nav.links
          a.link(href="/users/create") Добавить пользователя
